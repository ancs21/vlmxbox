{
  "name": "vlmxbox",
  "version": "0.0.3",
  "description": "Turnkey VLM server on Modal.com serverless GPU — one command to run open-source LLMs with vLLM",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/ancs21/vlmxbox"
  },
  "keywords": ["vllm", "modal", "gpu", "llm", "vlm", "serverless", "openai-compatible"],
  "bin": {
    "vlmxbox": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile vlmxbox",
    "test": "bun test",
    "test:e2e": "VLMXBOX_E2E=1 bun test src/__tests__/e2e.test.ts"
  },
  "dependencies": {
    "modal": "latest",
    "@clack/prompts": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
